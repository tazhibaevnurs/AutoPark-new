# Копируйте в .env и задайте значения. Для Docker — обязательно.
# Строки без решётки (#) — активные переменные; не комментируйте их в .env.

DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# USE_HTTPS=false — доступ по HTTP (по IP без SSL). После Certbot / SSL: true — редирект на HTTPS,
# HSTS, secure-куки (см. config/settings.py). Обязательно задайте CSRF_TRUSTED_ORIGINS с вашим доменом.
USE_HTTPS=false
# Со схемой https://, через запятую без пробелов — обязательно при USE_HTTPS=true (админка, формы, POST).
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DATABASE_PATH=/data/db.sqlite3
# Оба хоста (с www и без), через запятую без пробелов — иначе часть запросов получит 403 от CORS.
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
DJANGO_LOG_LEVEL=INFO
SUSPICIOUS_4XX_PER_IP_10MIN=30
ANOMALY_REQUESTS_PER_MINUTE=1500
API_RATE_LIMIT_PER_MINUTE=100
API_BODY_SIZE_LIMIT_BYTES=1048576
UPLOAD_BODY_SIZE_LIMIT_BYTES=10485760
YOOKASSA_WEBHOOK_SECRET=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
TELEGRAM_WEBHOOK_SECRET_TOKEN=replace-me
# Для preview-окружений используйте отдельную БД/переменные:
# APP_ENV=preview
# DATABASE_PATH=/data-preview/db.sqlite3
