# Копируйте в .env и задайте значения. Для Docker — обязательно.
# Строки без решётки (#) — активные переменные; не комментируйте их в .env.

DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# USE_HTTPS=false — доступ по HTTP (по IP без SSL). true — редирект на HTTPS (нужен сертификат).
USE_HTTPS=false
DATABASE_PATH=/data/db.sqlite3
